function groupClosingBalance($group, $entryItems = [], $all = [], $carryForwarded = [], $rate = 1, $openings = [])
{
    // Initialize totals
    $opening_balance = 0;
    $debit = 0;
    $credit = 0;
    
    // --- Step 1: Add ledger balances of current group ---
    $accounts = $all['accounts']
        ->where('account_group_id', $group->id)
        ->pluck('id')
        ->toArray();

    if (!empty($accounts)) {
        // 1.1 Carry Forward
        if (count($carryForwarded) > 0) {
            $opening_balance += $carryForwarded->whereIn('chart_of_account_id', $accounts)->sum('carry_forwarding_amount') * $rate;
        }
        
        // 1.2 Opening Transactions (D/C before start date)
        $opening_debit = 0;
        if (isset($openings['D']) && count($openings['D']) > 0) {
            $opening_debit = $openings['D']->whereIn('chart_of_account_id', $accounts)->sum('reporting_amount') * $rate;
        }
        
        $opening_credit = 0;
        if (isset($openings['C']) && count($openings['C']) > 0) {
            $opening_credit = $openings['C']->whereIn('chart_of_account_id', $accounts)->sum('reporting_amount') * $rate;
        }
        
        $opening_balance += actualValue($opening_debit, 'D') + actualValue($opening_credit, 'C');

        // 1.3 Period Transactions
        if (isset($entryItems['D'])) {
            $debit += $entryItems['D']->whereIn('chart_of_account_id', $accounts)->sum('reporting_amount') * $rate;
        }

        if (isset($entryItems['C'])) {
            $credit += $entryItems['C']->whereIn('chart_of_account_id', $accounts)->sum('reporting_amount') * $rate;
        }
    }
    
    // --- Step 2: Add balances of all child groups recursively ---
    $childGroups = $all['groups']->where('parent_id', $group->id);
    
    foreach ($childGroups as $child) {
        $childBalance = groupClosingBalance($child, $entryItems, $all, $carryForwarded, $rate, $openings);
        
        $opening_balance += $childBalance['opening_balance'];
        $debit += $childBalance['debit'];
        $credit += $childBalance['credit'];
    }
    
    // --- Step 3: Return total for this group (including subgroups & ledgers) ---
    return [
        'opening_balance' => $opening_balance, // Net signed
        'debit' => $debit,                      // Gross positive
        'credit' => $credit,                    // Gross positive
        'balance' => $opening_balance + actualValue($debit, 'D') + actualValue($credit, 'C'), // Net signed
    ];
}


function balanceSheet($company_id, $group, $from, $to, $step = 0, $link = true, $entryItems = [], $all = [], $carryForwarded = [], $rate = 1){
    $data = '';

    $chartOfAccounts = $all['accounts']->where('account_group_id', $group->id);
    if($chartOfAccounts->count() > 0){
        foreach($chartOfAccounts as $key => $account){
            $data .= '<tr class="account-'.$account->id.'">
                        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$from.'&to='.$to.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->code.($link ? '</a>' : '').'</td>
                        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$from.'&to='.$to.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->name.($link ? '</a>' : '').'</td>
                        <td class="amount closing_balance_column" style="text-align: right">'.systemMoneyFormat(ledgerClosingBalance($group, $account, $entryItems, $all, $carryForwarded, $rate)['balance']).'</td>
                    </tr>';
        }
    }

    $groups = collect($all['groups']->where('parent_id', $group->id))->sortBy('code');
    if($groups->count() > 0){
        foreach ($groups as $key => $group) {
            $childrenGroups = $all['groups']->where('parent_id', $group->id);
            $chartOfAccounts = $all['accounts']->where('account_group_id', $group->id);

            if($chartOfAccounts->count() > 0 || $childrenGroups->count() > 0){
                $data .= '<tr class="group-'.$group->id.'">
                            <td><strong>'.$group->code.'</strong></td>
                            <td><strong>'.$group->name.'</strong></td>
                            <td style="text-align: right" class="closing_balance_column"><strong>'.systemMoneyFormat(groupClosingBalance($group, $entryItems, $all, $carryForwarded, $rate)['balance']).'</strong></td>
                       </tr>';
            }

            if($chartOfAccounts->count() > 0){
                foreach($chartOfAccounts as $key => $account){
                    $data .= '<tr class="account-'.$account->id.'">
                                <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$from.'&to='.$to.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->code.($link ? '</a>' : '').'</td>
                                <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$from.'&to='.$to.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->name.($link ? '</a>' : '').'</td>
                                <td class="amount closing_balance_column" style="text-align: right">'.systemMoneyFormat(ledgerClosingBalance($group, $account, $entryItems, $all, $carryForwarded, $rate)['balance']).'</td>
                            </tr>';
                }
            }

            if($childrenGroups->count() > 0){
                $data .= balanceSheet($company_id, $group, $from, $to, $step+1, $link, $entryItems, $all, $carryForwarded, $rate);
            }
        }
    }
    
    return $data;
}

function balanceSheetLedger($company_id, $account, $from, $to, $step = 0, $link = true, $entryItems = [], $all = [], $carryForwarded = [], $rate = 1){
    $balance = ledgerClosingBalance($account->accountGroup, $account, $entryItems, $all, $carryForwarded, $rate);
    $data = '<tr class="account-'.$account->id.'">
        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$from.'&to='.$to.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->code.($link ? '</a>' : '').'</td>
        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$from.'&to='.$to.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->name.($link ? '</a>' : '').'</td>
        <td class="amount closing_balance_column" style="text-align: right">'.systemMoneyFormat($balance['balance']).'</td>
    </tr>';

    return [
        'balance' => $balance['balance'],
        'data' => $data,
    ];
}

function trialbalanceGroupData($group, $entryItems, $all, $carryForwarded, $rate, $openings, $step = 0){
    $group_balance = groupClosingBalance($group, $entryItems, $all, $carryForwarded, $rate, $openings);
    $padding = $step * 20;
    return '<tr class="group-'.$group->id.'">
        <td><strong style="padding-left: '.$padding.'px">'.$group->code.'</strong></td>
        <td><strong style="padding-left: '.$padding.'px">'.$group->name.'</strong></td>
        <td class="opening_balance_column" style="text-align: right"><strong>'.systemMoneyFormat($group_balance['opening_balance']).'</strong></td>
        <td class="debit_column" style="text-align: right"><strong>'.systemMoneyFormat($group_balance['debit']).'</strong></td>
        <td class="credit_column" style="text-align: right"><strong>'.systemMoneyFormat($group_balance['credit']).'</strong></td>
        <td class="closing_balance_column" style="text-align: right"><strong>'.systemMoneyFormat($group_balance['balance']).'</strong></td>
    </tr>';
}

function trialbalanceLedgerData($group, $account, $entryItems, $all, $carryForwarded, $rate, $openings, $link, $company_id, $start, $end, $step = 0){
    $ledger_balance = ledgerClosingBalance($group, $account, $entryItems, $all, $carryForwarded, $rate, $openings);
    $padding = ($step + 1) * 20;
    return '<tr class="account-'.$account->id.'">
        <td style="padding-left: '.$padding.'px">'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->code.($link ? '</a>' : '').'</td>
        <td style="padding-left: '.$padding.'px">'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->name.($link ? '</a>' : '').'</td>
        <td class="opening_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['opening_balance']).'</td>
        <td class="debit_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['debit']).'</td>
        <td class="credit_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['credit']).'</td>
        <td class="closing_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['balance']).'</td>
    </tr>';
}

function trialbalance($company_id, $group, $start, $end, $step = 0, $link = true, $openings = [], $entryItems = [], $all = [], $carryForwarded = [], $rate = 1){
    $data = '';

    // 1. Show individual ledgers belong to THIS group
    $chartOfAccounts = $all['accounts']->where('account_group_id', $group->id);
    if($chartOfAccounts->count() > 0){
        foreach($chartOfAccounts as $key => $account){
            $data .= trialbalanceLedgerData($group, $account, $entryItems, $all, $carryForwarded, $rate, $openings, $link, $company_id, $start, $end, $step);
        }
    }
    
    // 2. Show Child Groups
    $groups = collect($all['groups']->where('parent_id', $group->id))->sortBy('code');
    if($groups->count() > 0){
        foreach ($groups as $key => $childGroup) {
            $childrenGroupsCount = $all['groups']->where('parent_id', $childGroup->id)->count();
            $chartOfAccountsCount = $all['accounts']->where('account_group_id', $childGroup->id)->count();
            
            if($chartOfAccountsCount > 0 || $childrenGroupsCount > 0){
                // Show child group total row
                $data .= trialbalanceGroupData($childGroup, $entryItems, $all, $carryForwarded, $rate, $openings, $step + 1);
                
                // Recurse into child group (this will handle child ledgers and sub-sub-groups)
                $data .= trialbalance($company_id, $childGroup, $start, $end, $step + 1, $link, $openings, $entryItems, $all, $carryForwarded, $rate);
            }
        }
    }

    return $data;
}

function trialbalanceLedger($company_id, $account, $start, $end, $link = true, $openings = [], $entryItems = [], $all = [], $carryForwarded = [], $rate = 1){
    
    //$companyCode = optional($account->companies->where('id',$company_id))->pluck('company.code')->join(', ');
    $companyCode = $account->companies->where('company_id',$company_id)->pluck('company.code')->join(', ');
    
    $ledger_balance = ledgerClosingBalance($account->accountGroup, $account, $entryItems, $all, $carryForwarded, $rate, $openings);
    $data = '<tr class="account-'.$account->id.'">
        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='.$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->code.($link ? '</a>' : '').'</td>
        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?company_id='.$company_id.'&chart_of_account_id='
                .$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->name .'( '.
        $companyCode .')' .
        ($link ?
            '</a>' : '').'</td>
        <td class="opening_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['opening_balance']).'</td>
        <td class="debit_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['debit']).'</td>
        <td class="credit_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['credit']).'</td>
        <td class="closing_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['balance']).'</td>
    </tr>';

    return [
        'balance' => $ledger_balance,
        'data' => $data,
    ];
}

function trialbalanceOnlyClosingBalance($group, $start, $end, $currency_id = 1, $step = 0, $link = true, $exchangeRates = [], $entryItems = [], $all = [], $company_id = 0, $fiscal_year_id = 0, $carryForwarded = []){
    $data = '';
    
    // 1. Show ledgers of current group
    $chartOfAccounts = $all['accounts']->where('account_group_id', $group->id);
    if($chartOfAccounts->count() > 0){
        foreach($chartOfAccounts as $key => $account){
            $ledger_balance = ledgerClosingBalance($group, $account, $start, $end, $currency_id, $exchangeRates, $entryItems, $all, $company_id, $fiscal_year_id, $carryForwarded);
            $padding = ($step + 1) * 20;
            $data .= '<tr class="account-'.$account->id.'">
                        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?chart_of_account_id='.$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').'<span style="padding-left: '.$padding.'px">['.$account->code.'] '.$account->name.'</span>'.($link ? '</a>' : '').'</td>
                        <td class="opening_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['opening_balance']).'</td>
                        <td class="closing_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['balance']).'</td>
                    </tr>';
        }
    }

    // 2. Show Child Groups
    $groups = collect($all['groups']->where('parent_id', $group->id))->sortBy('code');
    foreach ($groups as $key => $childGroup) {
        $childrenGroupsCount = $all['groups']->where('parent_id', $childGroup->id)->count();
        $chartOfAccountsCount = $all['accounts']->where('account_group_id', $childGroup->id)->count();
        
        if($chartOfAccountsCount > 0 || $childrenGroupsCount > 0){
            $group_balance = groupClosingBalance($childGroup, $start, $end, $currency_id, [], $exchangeRates, $entryItems, $all, $company_id, $fiscal_year_id, $carryForwarded);
            $padding = ($step + 1) * 20;
            $data .= '<tr class="group-'.$childGroup->id.'">
                            <td><strong style="padding-left: '.$padding.'px">['.$childGroup->code.'] '.$childGroup->name.'</strong></td>
                            <td class="opening_balance_column" style="text-align: right"><strong>'.systemMoneyFormat($group_balance['opening_balance']).'</strong></td>
                            <td class="closing_balance_column" style="text-align: right"><strong>'.systemMoneyFormat($group_balance['balance']).'</strong></td>
                       </tr>';

            // Recurse
            $data .= trialbalanceOnlyClosingBalance($childGroup, $start, $end, $currency_id, $step + 1, $link, $exchangeRates, $entryItems, $all, $company_id, $fiscal_year_id, $carryForwarded);
        }
    }

    return $data;
}

function trialbalanceOnlyClosingBalanceLedger($account, $start, $end, $currency_id = 1, $link = true, $exchangeRates = [], $entryItems = [], $all = [], $company_id = 0, $fiscal_year_id = 0, $carryForwarded = []){
    $ledger_balance = ledgerClosingBalance($account->accountGroup, $account, $start, $end, $currency_id, $exchangeRates, $entryItems, $all, $company_id, $fiscal_year_id, $carryForwarded);
    $data = '<tr class="account-'.$account->id.'">
        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?chart_of_account_id='.$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->code.($link ? '</a>' : '').'</td>
        <td>'.($link ? '<a href="'.url('accounting/ledger-statement?chart_of_account_id='.$account->id.'&from='.$start.'&to='.$end.'&fiscal_year_id='.request()->get('fiscal_year_id')).'" target="_blank">' : '').$account->name.($link ? '</a>' : '').'</td>
        <td class="opening_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['opening_balance']).'</td>
        <td class="closing_balance_column" style="text-align: right">'.systemMoneyFormat($ledger_balance['balance']).'</td>
    </tr>';

    return [
        'balance' => $ledger_balance,
        'data' => $data,
    ];
}

