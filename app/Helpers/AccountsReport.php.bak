<?php

function actualValue($amount = 0, $type = 'D'){
    $positive = isPositive($type);
    $amount = ($positive ? $amount : ($amount*(-1)));
    return ($amount == -0 ? 0 : $amount);
}

function isPositive($type){
    $positive = false;
    if($type == "D"){
        $positive = true;
    }elseif($type == "C"){
        $positive = false;
    }

    return $positive;
}

// old
// old
function ledgerClosingBalance($group, $account, $entryItems = [], $all = [], $carryForwarded = [], $rate = 1, $openings = [], $sub_ledgers = []){
    $opening_balance = 0;
    $debit = 0;
    $credit = 0;
    if(isset($account->id)){
        $coa_id = $account->id;

        // Opening Balance (Carry Forward)
        if (count($carryForwarded) > 0) {
            if ($carryForwarded->has($coa_id) && $carryForwarded->get($coa_id)->chart_of_account_id == $coa_id) {
                $opening_balance = $carryForwarded->get($coa_id)->carry_forwarding_amount * $rate;
            } else {
                $opening_balance = $carryForwarded->where('chart_of_account_id', $coa_id)->sum('carry_forwarding_amount') * $rate;
            }
        }

        // Opening Transactions
        $opening_debit = 0;
        if (isset($openings['D']) && $openings['D']->count() > 0) {
            if ($openings['D']->has($coa_id) && $openings['D']->get($coa_id)->chart_of_account_id == $coa_id) {
                $opening_debit = $openings['D']->get($coa_id)->reporting_amount * $rate;
            } else {
                $opening_debit = $openings['D']->where('chart_of_account_id', $coa_id)->sum('reporting_amount') * $rate;
            }
        }

        $opening_credit = 0;
        if (isset($openings['C']) && $openings['C']->count() > 0) {
            if ($openings['C']->has($coa_id) && $openings['C']->get($coa_id)->chart_of_account_id == $coa_id) {
                $opening_credit = $openings['C']->get($coa_id)->reporting_amount * $rate;
            } else {
                $opening_credit = $openings['C']->where('chart_of_account_id', $coa_id)->sum('reporting_amount') * $rate;
            }
        }

        // Period Transactions
        if(isset($sub_ledgers[0])){
            $debit = $entryItems['D']->where('chart_of_account_id', $coa_id)->whereIn('sub_ledger_id', $sub_ledgers)->sum('reporting_amount')*$rate;
            $credit = $entryItems['C']->where('chart_of_account_id', $coa_id)->whereIn('sub_ledger_id', $sub_ledgers)->sum('reporting_amount')*$rate;
        }else{
            if (isset($entryItems['D'])) {
                if ($entryItems['D']->has($coa_id) && $entryItems['D']->get($coa_id)->chart_of_account_id == $coa_id) {
                    $debit = $entryItems['D']->get($coa_id)->reporting_amount * $rate;
                } else {
                    $debit = $entryItems['D']->where('chart_of_account_id', $coa_id)->sum('reporting_amount') * $rate;
                }
            }

            if (isset($entryItems['C'])) {
                if ($entryItems['C']->has($coa_id) && $entryItems['C']->get($coa_id)->chart_of_account_id == $coa_id) {
                    $credit = $entryItems['C']->get($coa_id)->reporting_amount * $rate;
                } else {
                    $credit = $entryItems['C']->where('chart_of_account_id', $coa_id)->sum('reporting_amount') * $rate;
                }
            }
        }
    }

    $opening_balance = $opening_balance + actualValue($opening_debit, 'D') + actualValue($opening_credit, 'C');
    return [
        'opening_balance' => $opening_balance,
        'debit' => $debit,
        'credit' => $credit,
        'balance' => $opening_balance + actualValue($debit, 'D') + actualValue($credit, 'C'),
    ];
}
